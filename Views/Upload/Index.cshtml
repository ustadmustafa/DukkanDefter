@model DukkanDefterOCR.Models.ManualEntryViewModel
@{
    ViewData["Title"] = "Defter Girişi";
    var googleSheetOpenUrl = ViewData["GoogleSpreadsheetOpenUrl"] as string;
}

<div class="ledger-card card border-0 mx-auto" style="max-width: 52rem;">
    <div class="card-body p-4 p-md-5">
        <h1 class="h3 card-title fw-bold mb-1">Defter Girişi</h1>
        <p class="text-muted small mb-4 mb-md-4">
            Kayıt <strong>Google Sheet</strong> sekmesine yazılır: kasaya girilen para, harcamalar, kasa, yüklenen akbil, toplam harcamalar, satılan akbil, gün sonu ve ciro (önceki günün sekmesindeki <strong>Kasa</strong> ve <strong>Devredecek Akbil</strong> değerleri ciro ve devir alınan için kullanılır).
        </p>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success border-0 shadow-sm mb-4" role="alert">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger border-0 shadow-sm mb-4" role="alert">@TempData["Error"]</div>
        }

        <form asp-action="Save" asp-controller="Upload" method="post" id="ledgerForm">
            @Html.AntiForgeryToken()

            <div class="mb-4">
                <label class="form-label fw-semibold small text-uppercase text-muted" style="letter-spacing: .05em;" asp-for="SheetDate">Sekme adı (tarih)</label>
                <input class="form-control form-control-lg" asp-for="SheetDate" placeholder="örn. 04.04.26" autocomplete="off" />
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold small text-uppercase text-muted" style="letter-spacing: .05em;" asp-for="KasayaGirilenPara">Kasaya Girilen Para</label>
                <input class="form-control form-control-lg text-end js-ledger-num" asp-for="KasayaGirilenPara" type="number" inputmode="numeric" step="1" placeholder="0" />
            </div>

            <div class="table-responsive ledger-table-wrap mb-3">
                <table class="table table-hover mb-0 ledger-table" id="rowsTable">
                    <thead>
                        <tr>
                            <th class="ps-3 ps-md-4">Ürün (harcama)</th>
                            <th class="text-end pe-2" style="min-width: 8.5rem;">Tutar</th>
                            <th class="text-center px-2" style="width: 3.5rem;"></th>
                        </tr>
                    </thead>
                    <tbody id="rowsBody">
                        @for (var i = 0; i < Model.Rows.Count; i++)
                        {
                            <tr class="data-row">
                                <td class="ps-3 ps-md-4 py-3">
                                    <input class="form-control" name="Rows[@i].Urun" value="@Model.Rows[i].Urun" autocomplete="off" placeholder="Örn. Yemek" />
                                </td>
                                <td class="py-3 pe-2">
                                    <input class="form-control text-end js-tutar" name="Rows[@i].Tutar" value="@(Model.Rows[i].Tutar == 0 ? "" : Model.Rows[i].Tutar.ToString())" type="number" inputmode="numeric" min="0" step="1" placeholder="0" />
                                </td>
                                <td class="text-center py-3 px-1">
                                    <button type="button" class="btn btn-sm btn-outline-danger btn-icon-remove btn-remove-row" title="Satırı sil" aria-label="Satırı sil">✕</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold small text-uppercase text-muted" style="letter-spacing: .05em;" asp-for="Kasa">Kasa</label>
                    <input class="form-control form-control-lg text-end js-ledger-num" asp-for="Kasa" type="number" inputmode="numeric" step="1" placeholder="0" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold small text-uppercase text-muted" style="letter-spacing: .05em;" asp-for="YuklenenAkbil">Yüklenen Akbil</label>
                    <input class="form-control form-control-lg text-end js-ledger-num" asp-for="YuklenenAkbil" type="number" inputmode="numeric" step="1" placeholder="0" />
                </div>
            </div>

            <div class="border rounded-3 p-3 mb-4 bg-light-subtle">
                <div class="row g-2 small">
                    <div class="col-sm-6 d-flex justify-content-between"><span class="text-muted">Önizleme toplamı (harcama)</span><span class="fw-semibold" id="liveTotal">0</span></div>
                    <div class="col-sm-6 d-flex justify-content-between"><span class="text-muted">Gün Sonu</span><span class="fw-semibold" id="liveGunSonu">0</span></div>
                    <div class="col-sm-6 d-flex justify-content-between"><span class="text-muted">Satılan Akbil</span><span class="fw-semibold" id="liveSatilan">0</span></div>
                    <div class="col-sm-6 d-flex justify-content-between"><span class="text-muted">Ciro</span><span class="fw-semibold" id="liveCiro">0</span></div>
                    <div class="col-12 pt-2 border-top mt-2">
                        <span class="text-muted">Devir Alınan Akbil</span> (bir önceki günün <em>Devredecek Akbil</em> değeri, kayıtta sunucudan okunur):
                        <span class="fw-bold text-teal" style="color: #0f766e;">@Model.DevirAlinanAkbilPreview.ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("tr-TR"))</span>
                    </div>
                </div>
            </div>

            <input type="hidden" id="hfDevirAlinan" value="@Model.DevirAlinanAkbilPreview" />
            <input type="hidden" id="hfDunKasa" value="@Model.DunKasaFromPreviousDay" />

            <div class="mb-4">
                <label class="form-label fw-semibold small text-uppercase text-muted" style="letter-spacing: .05em;" asp-for="DevredecekAkbil">Devredecek Akbil</label>
                <input class="form-control form-control-lg text-end js-ledger-num" asp-for="DevredecekAkbil" type="number" inputmode="numeric" step="1" placeholder="0" />
            </div>

            <div class="live-total-bar px-3 py-3 mb-4 d-flex flex-column flex-sm-row align-items-start align-items-sm-center justify-content-between gap-2">
                <span class="small text-muted fw-medium mb-0">Yalnızca ürün adı dolu satırlar kaydedilir.</span>
            </div>

            <div class="d-flex flex-column flex-sm-row flex-wrap gap-2 gap-sm-3 align-items-stretch align-items-sm-center">
                <button type="button" class="btn btn-ledger-outline order-3 order-sm-1" id="btnAddRow">+ Satır ekle</button>
                <div class="d-flex flex-column flex-sm-row gap-2 order-1 order-sm-2 flex-grow-1 flex-sm-grow-0">
                    <button type="submit" class="btn btn-ledger-primary flex-grow-1 flex-sm-grow-0">Google Sheets’e kaydet</button>
                    @if (!string.IsNullOrWhiteSpace(googleSheetOpenUrl))
                    {
                        <a href="@googleSheetOpenUrl" target="_blank" rel="noopener noreferrer" class="btn btn-ledger-outline flex-grow-1 flex-sm-grow-0">Sheets’i aç</a>
                    }
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const tbody = document.getElementById('rowsBody');
            const btnAdd = document.getElementById('btnAddRow');
            const liveTotal = document.getElementById('liveTotal');
            const liveGunSonu = document.getElementById('liveGunSonu');
            const liveSatilan = document.getElementById('liveSatilan');
            const liveCiro = document.getElementById('liveCiro');
            const hfDevir = document.getElementById('hfDevirAlinan');
            const hfDunKasa = document.getElementById('hfDunKasa');

            function parseIntSafe(v) {
                const n = parseInt(String(v).replace(/\s/g, ''), 10);
                return isNaN(n) ? 0 : n;
            }

            function expenseSum() {
                let sum = 0;
                tbody.querySelectorAll('tr.data-row').forEach(tr => {
                    const name = tr.querySelector('input[name$=".Urun"]');
                    const amt = tr.querySelector('input.js-tutar');
                    if (!name || !amt) return;
                    if (!name.value || !name.value.trim()) return;
                    sum += parseIntSafe(amt.value);
                });
                return sum;
            }

            function valByName(name) {
                const el = document.querySelector('[name="' + name + '"]');
                return el ? parseIntSafe(el.value) : 0;
            }

            function updateLive() {
                const harcama = expenseSum();
                const kasaya = valByName('KasayaGirilenPara');
                const kasa = valByName('Kasa');
                const yuklenen = valByName('YuklenenAkbil');
                const devredecek = valByName('DevredecekAkbil');
                const devirAlinan = hfDevir ? parseIntSafe(hfDevir.value) : 0;
                const dunKasa = hfDunKasa ? parseIntSafe(hfDunKasa.value) : 0;

                const gunSonu = harcama + yuklenen - kasaya + kasa;
                const satilan = devredecek + yuklenen - devirAlinan;
                const ciro = gunSonu - dunKasa - satilan;

                const tr = new Intl.NumberFormat('tr-TR');
                liveTotal.textContent = tr.format(harcama);
                liveGunSonu.textContent = tr.format(gunSonu);
                liveSatilan.textContent = tr.format(satilan);
                liveCiro.textContent = tr.format(ciro);
            }

            function rowCount() {
                return tbody.querySelectorAll('tr.data-row').length;
            }

            function reindexRows() {
                tbody.querySelectorAll('tr.data-row').forEach((tr, i) => {
                    const urun = tr.querySelector('input[name$=".Urun"]');
                    const tutar = tr.querySelector('input[name$=".Tutar"]');
                    if (urun) urun.name = 'Rows[' + i + '].Urun';
                    if (tutar) tutar.name = 'Rows[' + i + '].Tutar';
                });
                updateLive();
            }

            function addRow() {
                const i = rowCount();
                const tr = document.createElement('tr');
                tr.className = 'data-row';
                tr.innerHTML =
                    '<td class="ps-3 ps-md-4 py-3"><input class="form-control" name="Rows[' + i + '].Urun" autocomplete="off" placeholder="Örn. Yemek" /></td>' +
                    '<td class="py-3 pe-2"><input class="form-control text-end js-tutar" name="Rows[' + i + '].Tutar" type="number" inputmode="numeric" min="0" step="1" placeholder="0" /></td>' +
                    '<td class="text-center py-3 px-1"><button type="button" class="btn btn-sm btn-outline-danger btn-icon-remove btn-remove-row" title="Satırı sil" aria-label="Satırı sil">✕</button></td>';
                tbody.appendChild(tr);
                tr.querySelector('.btn-remove-row').addEventListener('click', onRemove);
                tr.querySelectorAll('input').forEach(inp => inp.addEventListener('input', updateLive));
                updateLive();
            }

            function onRemove(e) {
                const tr = e.target.closest('tr.data-row');
                if (!tr || rowCount() <= 1) return;
                tr.remove();
                reindexRows();
            }

            btnAdd.addEventListener('click', addRow);
            tbody.querySelectorAll('.btn-remove-row').forEach(b => b.addEventListener('click', onRemove));
            tbody.querySelectorAll('input').forEach(inp => inp.addEventListener('input', updateLive));
            document.querySelectorAll('.js-ledger-num').forEach(inp => inp.addEventListener('input', updateLive));
            updateLive();
        })();
    </script>
}
